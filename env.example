# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Sign up free: https://cloud.mongodb.com
# → Create a cluster → Connect → Drivers → copy the connection string
# Under Network Access, allow 0.0.0.0/0 (Vercel uses dynamic IPs)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/home-kiosk?retryWrites=true&w=majority

# PIN for kiosk access (must be exactly 6 digits)
KIOSK_PIN=123456

# Random string used to sign the auth cookie — change this to something secret
# Generate one with: openssl rand -hex 32
AUTH_SALT=change-me-to-a-random-string

# Anthropic API key — required for AI Chat
# Sign up: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron jobs & agent integration ─────────────────────────────────────────────

# Bearer token for Vercel cron requests — set to any random string
CRON_SECRET=change-me-to-a-random-string

# Bearer token for external agent (WhatsApp bot) access to /api/agent/*
AGENT_API_KEY=change-me-to-a-random-string

# ── Optional features ──────────────────────────────────────────────────────────

# Cloudinary — dish image uploads (app works without, but upload button will fail)
# Sign up free: https://cloudinary.com → Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Tavily — recipe web search in Add Dish modal and AI Chat (free: 1,000 searches/month)
# Sign up free: https://tavily.com
TAVILY_API_KEY=

# ICS calendar feed URL — external calendar to sync into the schedule
ICS_FEED_URL=

# Secret for the outbound /api/ical endpoint (subscribe to the app's calendar externally)
ICAL_SECRET=change-me-to-a-random-string
