# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─────────────────────────────────────────────────────────────────────────────
# IGNORED IN BOTH PUBLIC AND PRIVATE REPOS
# ─────────────────────────────────────────────────────────────────────────────

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — actual secrets, never commit
# (.env.example / env.example templates should be committed as documentation)
.env
.env.local
.env*.local
.env.production
.env.staging

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# IGNORED IN PUBLIC REPO ONLY — track these in your private repo (extension of public one)
# ─────────────────────────────────────────────────────────────────────────────

# real family config (private repo tracks this; public repo uses family.example.ts)
config/family.ts

# household-specific seed and migration scripts
# (contain real member IDs, school names, personal timetable data)
scripts/*
